{
  "bash": {
    "deny": {
      "rm -rf /": "🚨 禁止删除根目录",
      "rm -rf ~": "🚨 禁止删除用户目录",
      "rm -rf $HOME": "🚨 禁止删除用户目录",
      "sudo *": "🚨 禁止 sudo 操作",
      "shutdown *": "🚨 禁止关机",
      "reboot *": "🚨 禁止重启",
      "mkfs *": "🚨 禁止格式化磁盘",
      "mkfs* *": "🚨 禁止格式化磁盘",
      "dd if=*": "🚨 禁止 dd 写盘",
      "> /dev/sd*": "🚨 禁止写磁盘设备",
      "curl * | bash": "🚨 禁止远程代码执行",
      "curl * | sh": "🚨 禁止远程代码执行",
      "wget * | bash": "🚨 禁止远程代码执行",
      "wget * | sh": "🚨 禁止远程代码执行"
    },
    "allow": {
      "cat *": true,
      "head *": true,
      "tail *": true,
      "less *": true,
      "more *": true,
      "wc *": true,
      "file *": true,
      "stat *": true,
      "ls *": true,
      "tree *": true,
      "find *": true,
      "grep *": true,
      "rg *": true,
      "which *": true,
      "date": true,
      "date *": true,
      "pwd": true,
      "git status": true,
      "git log *": true,
      "git diff *": true,
      "git show *": true,
      "git branch *": true,
      "git tag *": true,
      "git remote *": true,
      "git describe *": true,
      "git blame *": true,
      "git reflog *": true,
      "git stash list": true,
      "ps *": true,
      "top *": true,
      "htop *": true,
      "df *": true,
      "du *": true,
      "free *": true,
      "uptime *": true,
      "uname *": true,
      "id": true,
      "whoami": true,
      "w": true,
      "last *": true,
      "lsof *": true,
      "npm list *": true,
      "npm info *": true,
      "npm view *": true,
      "npm outdated *": true,
      "npm audit *": true,
      "yarn list *": true,
      "pnpm list *": true,
      "pip list *": true,
      "pip show *": true,
      "pip freeze *": true,
      "cargo tree *": true,
      "cargo list *": true,
      "go list *": true,
      "go env *": true,
      "go version": true,
      "docker ps *": true,
      "docker images *": true,
      "docker logs *": true,
      "docker inspect *": true,
      "docker version": true,
      "docker info": true,
      "docker stats *": true,
      "docker top *": true,
      "zcat *": true,
      "zgrep *": true,
      "zless *": true,
      "zmore *": true,
      "zdiff *": true,
      "unzip -l *": true,
      "zipinfo *": true,
      "tar *-t*": true,
      "tar *-Z*": true,
      "awk *": true,
      "sed *": true,
      "jq *": true,
      "sort *": true,
      "uniq *": true,
      "cut *": true,
      "tr *": true,
      "tee *": true,
      "diff *": true,
      "comm *": true,
      "paste *": true,
      "join *": true,
      "column *": true,
      "fmt *": true,
      "fold *": true,
      "curl *": true,
      "wget *": true,
      "ping *": true,
      "dig *": true,
      "nslookup *": true,
      "host *": true,
      "traceroute *": true,
      "whois *": true,
      "netstat *": true,
      "ss *": true,
      "ip addr *": true,
      "bun test": true,
      "bun test *": true,
      "bun run *": true
    }
  },
  "path": {
    "deny": {
      "*.env": "🔒 禁止访问环境变量文件",
      "*.env.*": "🔒 禁止访问环境变量文件",
      "~/.ssh/*": "🔒 禁止访问 SSH 密钥",
      "~/.gnupg/*": "🔒 禁止访问 GPG 密钥"
    },
    "allow": {
      "*.env.example": true,
      "*.env.template": true
    }
  }
}
